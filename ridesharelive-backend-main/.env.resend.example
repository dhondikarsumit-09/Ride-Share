# ==========================================
# RESEND EMAIL CONFIGURATION
# ==========================================
# To use Resend for sending OTP emails:

# Set mail provider to "resend"
MAIL_PROVIDER=resend

# Your Resend API Key (get from https://resend.com)
RESEND_API_KEY=re_your_api_key_here

# From address (must be verified in Resend)
RESEND_FROM_ADDRESS=noreply@yourdomain.com

# Display name for emails
MAIL_FROM_NAME=RideShare Live

# Enable OTP emails
MAIL_OTP_ENABLED=true

# ==========================================
# OR: Use Traditional SMTP (Gmail)
# ==========================================
# Keep MAIL_PROVIDER=smtp or empty

# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-16-char-app-password
# MAIL_FROM_ADDRESS=your-email@gmail.com
